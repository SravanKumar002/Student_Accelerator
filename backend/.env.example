# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# NEVER commit .env to version control!
# =============================================================================

# Server port (default: 5001)
PORT=5001

# MongoDB connection string
# Local:  mongodb://localhost:27017/student-accelerator
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/<db>
MONGODB_URI=mongodb+srv://your_user:your_pass@cluster.mongodb.net/student-accelerator

# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# Node environment: development | production
NODE_ENV=development

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
